# Copia a .env y rellena los valores. NO comitees tu .env real.

# Puerto público de la web
PORT=8000

# Base de datos
DB_NAME=openrepair
DB_USER=openrepair_user
DB_PASSWORD=cambia-esta-contrasena
DB_ROOT_PASSWORD=cambia-esta-root
# Solo para desarrollo local sin Docker (con Docker se usa "db")
DB_HOST=localhost

# Clave de sesiones Flask — genera una aleatoria:
#   python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esta-clave

# Admin inicial: se crea solo la 1ª vez que arranca (si no hay usuarios).
# Cámbialos antes de exponer la app.
ADMIN_EMAIL=admin@openrepair.com
ADMIN_PASSWORD=admin123
